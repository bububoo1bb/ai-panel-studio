# AI Panel Studio — Backend Environment Variables
#
# Copy this file to .env and adjust values for your environment.
# Never commit a real .env file with actual credentials.

# AI provider selection: "mock" (default) or "deepseek"
AI_PROVIDER=mock

# DeepSeek configuration (required only when AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
